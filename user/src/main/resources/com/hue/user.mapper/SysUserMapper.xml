        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hue.user.mapper.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.hue.user.pojo.SysUser">
            <id property="id" column="id" />
